# Copy this file to ".env" and fill it in. Only 1 Spotify "app" is needed
# for the whole project (see README), shared by everyone taking part.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# These lines are added automatically by auth.py - one per person.
# Don't fill these in by hand, except to remove someone.
# The name is REFRESH_TOKEN_<ID>, where <ID> exactly matches the "id"
# field of that person in config.json (uppercased).
REFRESH_TOKEN_YOU=
REFRESH_TOKEN_FRIEND=

# The Spotify link (or just the ID) of each shared playlist, one line
# per playlist block in config.json. Name is PLAYLIST_ID_<NAME>, where
# <NAME> is that playlist's "name" field (uppercased, spaces/dashes -> _).
# This lives here instead of in config.json, so config.json never has
# to contain real playlist links if you put this project on GitHub.
PLAYLIST_ID_YOU_AND_FRIEND=
